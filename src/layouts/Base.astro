---
import { getCollection } from 'astro:content';
import publicationsCache from '../../data/.publications_cache.json';
import '../styles/global.css';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, breadcrumbs = [] } = Astro.props;
const pageTitle = title ? `${title} — NMPP Division at IPP` : 'NMPP Division at IPP';

const codes = await getCollection('codes');
const codeList = [...codes].sort((a, b) => a.data.title.localeCompare(b.data.title));

const groups = await getCollection('groups');
const groupList = [...groups].sort((a, b) => a.data.title.localeCompare(b.data.title));

type SearchItem = {
  type: 'Member' | 'Code' | 'Publication';
  title: string;
  href: string;
  subtitle?: string;
  keywords?: string;
};

const publications: Array<Record<string, unknown>> = Array.isArray(publicationsCache)
  ? publicationsCache
  : [];

const memberSearchItems: SearchItem[] = (await getCollection('members')).map(member => ({
  type: 'Member',
  title: member.data.title,
  href: `/members/${member.slug}/`,
}));

const codeSearchItems: SearchItem[] = codes.map(code => ({
  type: 'Code',
  title: code.data.title,
  href: `/codes/${code.slug}/`,
}));

const publicationSearchItems: SearchItem[] = publications
  .filter(pub => typeof pub.title === 'string' && typeof pub.doi === 'string')
  .map(pub => ({
    type: 'Publication',
    title: String(pub.title),
    href: typeof pub.slug === 'string' && pub.slug
      ? `/publications/${String(pub.slug)}/`
      : `https://doi.org/${String(pub.doi)}`,
    subtitle: [pub.year, pub.authors]
      .filter(value => typeof value === 'string' || typeof value === 'number')
      .join(' · '),
    keywords: [pub.authors, pub.venue, pub.journal, pub.abstract, pub.year, pub.doi]
      .filter(value => typeof value === 'string' || typeof value === 'number')
      .join(' '),
  }));

const siteSearchItems = [...memberSearchItems, ...codeSearchItems, ...publicationSearchItems];
const siteSearchJson = JSON.stringify(siteSearchItems);

const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <script>
      (() => {
        const stored = localStorage.getItem('nmpp-theme');
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored === 'dark' || stored === 'light' ? stored : (systemPrefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-inner" aria-label="Main navigation">
        <a href="/" class="nav-logo">NMPP</a>

        <button
          class="nav-toggle"
          id="nav-toggle"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="nav-links"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="2" y1="5" x2="18" y2="5" />
            <line x1="2" y1="10" x2="18" y2="10" />
            <line x1="2" y1="15" x2="18" y2="15" />
          </svg>
        </button>

        <ul class="nav-links" id="nav-links" role="list">
          <li class={path === '/' ? 'nav-active' : ''}>
            <a href="/">Home</a>
          </li>
          <li class={path.startsWith('/codes') ? 'nav-active' : ''}>
            <a href="/codes/">Codes</a>
            <ul class="nav-dropdown" role="list">
              <li><a href="/codes/">Overview</a></li>
              {codeList.map(code => (
                <li>
                  <a href={`/codes/${code.slug}/`}>{code.data.title}</a>
                </li>
              ))}
            </ul>
          </li>
          <li class={path.startsWith('/publications') ? 'nav-active' : ''}>
            <a href="/publications/">Publications</a>
          </li>
          <li class={path.startsWith('/dissertations') ? 'nav-active' : ''}>
            <a href="/dissertations/">Dissertations</a>
          </li>
          <li class={path.startsWith('/groups') ? 'nav-active' : ''}>
            <a href="/groups/">Groups</a>
            <ul class="nav-dropdown" role="list">
              <li><a href="/groups/">Overview</a></li>
              {groupList.map(group => (
                <li>
                  <a href={`/groups/${group.slug}/`}>{group.data.title}</a>
                </li>
              ))}
            </ul>
          </li>
          <li class={path.startsWith('/members') ? 'nav-active' : ''}>
            <a href="/members/">Members</a>
          </li>
        </ul>

        <div class="site-search" role="search" aria-label="Site search">
          <label for="site-search-input" class="sr-only">Search members, codes, and publications</label>
          <input
            id="site-search-input"
            type="search"
            placeholder="Search members, codes, publications..."
            autocomplete="off"
          />
          <div id="site-search-results" class="site-search-results" hidden></div>
        </div>

        <button
          id="theme-toggle"
          class="theme-toggle"
          type="button"
          aria-label="Toggle dark mode"
          title="Toggle dark mode"
        >
          <span class="theme-toggle-light" aria-hidden="true">Light</span>
          <span class="theme-toggle-dark" aria-hidden="true">Dark</span>
        </button>
      </nav>
    </header>

    <main>
      {breadcrumbs.length > 0 && (
        <div class="site-breadcrumb-wrap">
          <nav aria-label="Breadcrumb" class="site-breadcrumb">
            <ol>
              {breadcrumbs.map((crumb, index) => (
                <li>
                  {crumb.href && index < breadcrumbs.length - 1 ? (
                    <a href={crumb.href}>{crumb.label}</a>
                  ) : (
                    <span aria-current="page">{crumb.label}</span>
                  )}
                </li>
              ))}
            </ol>
          </nav>
        </div>
      )}
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <span>NMPP Division · Max Planck Institute for Plasma Physics</span>
        <span>
          <a href="https://www.ipp.mpg.de/ippcms/eng/for/bereiche/numerik" target="_blank" rel="noopener noreferrer">IPP webpage</a>
          &middot;
          <a href="https://github.com/nmpp-hub/nmpp-hub.github.io" target="_blank" rel="noopener noreferrer">GitHub</a>
        </span>
      </div>
    </footer>

    <button id="back-to-top" class="back-to-top" aria-label="Back to top" title="Back to top">
      Top
    </button>

    <script id="site-search-data" type="application/json" set:html={siteSearchJson}></script>

    <script>
      const toggle = document.getElementById('nav-toggle') as HTMLButtonElement | null;
      const links = document.getElementById('nav-links') as HTMLElement | null;
      if (toggle && links) {
        toggle.addEventListener('click', () => {
          const open = links.classList.toggle('nav-open');
          toggle.setAttribute('aria-expanded', String(open));
        });
      }

      const themeToggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;
      const currentTheme = document.documentElement.getAttribute('data-theme');
      if (themeToggle) {
        const syncLabel = () => {
          const theme = document.documentElement.getAttribute('data-theme') ?? 'light';
          themeToggle.setAttribute('aria-pressed', String(theme === 'dark'));
        };

        themeToggle.addEventListener('click', () => {
          const next = (document.documentElement.getAttribute('data-theme') === 'dark') ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('nmpp-theme', next);
          syncLabel();
        });

        if (!currentTheme) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
        syncLabel();
      }

      const searchInput = document.getElementById('site-search-input') as HTMLInputElement | null;
      const searchResults = document.getElementById('site-search-results') as HTMLDivElement | null;
      const searchDataScript = document.getElementById('site-search-data') as HTMLScriptElement | null;

      function normalize(value: string): string {
        return value
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim();
      }

      function escapeHtml(value: string): string {
        return value
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      }

      type SearchItem = {
        type: 'Member' | 'Code' | 'Publication';
        title: string;
        href: string;
        subtitle?: string;
        keywords?: string;
      };

      let searchItems: SearchItem[] = [];
      if (searchDataScript?.textContent) {
        try {
          const parsed = JSON.parse(searchDataScript.textContent);
          if (Array.isArray(parsed)) {
            searchItems = parsed.filter(item => item && typeof item === 'object') as SearchItem[];
          }
        } catch {
          searchItems = [];
        }
      }

      function renderSearchResults(query: string): void {
        if (!searchResults) return;
        const cleaned = normalize(query);
        if (!cleaned) {
          searchResults.hidden = true;
          searchResults.innerHTML = '';
          return;
        }

        const matched = searchItems
          .filter(item => {
            const haystack = normalize(`${item.type} ${item.title} ${item.subtitle ?? ''} ${item.keywords ?? ''}`);
            return haystack.includes(cleaned);
          })
          .slice(0, 10);

        if (matched.length === 0) {
          searchResults.hidden = false;
          searchResults.innerHTML = '<p class="site-search-empty">No results</p>';
          return;
        }

        searchResults.hidden = false;
        searchResults.innerHTML = matched
          .map(item => {
            const subtitle = item.subtitle ? `<span class="site-search-item-subtitle">${escapeHtml(item.subtitle)}</span>` : '';
            return `<a class="site-search-item" href="${escapeHtml(item.href)}">
              <span class="site-search-item-type">${escapeHtml(item.type)}</span>
              <span class="site-search-item-title">${escapeHtml(item.title)}</span>
              ${subtitle}
            </a>`;
          })
          .join('');
      }

      if (searchInput && searchResults) {
        searchInput.addEventListener('input', () => renderSearchResults(searchInput.value));
        searchInput.addEventListener('focus', () => renderSearchResults(searchInput.value));
        document.addEventListener('click', event => {
          const target = event.target as Node;
          if (!searchResults.contains(target) && !searchInput.contains(target)) {
            searchResults.hidden = true;
          }
        });
      }

      document.querySelectorAll<HTMLInputElement>('.section-search-input').forEach(input => {
        input.addEventListener('input', () => {
          const section = input.closest('.searchable-section');
          if (!section) return;
          const query = input.value.trim().toLowerCase();
          section.querySelectorAll<HTMLElement>('tbody tr').forEach(row => {
            row.style.display = query === '' || (row.textContent ?? '').toLowerCase().includes(query) ? '' : 'none';
          });
          section.querySelectorAll<HTMLElement>('.publication-card').forEach(card => {
            card.style.display = query === '' || (card.textContent ?? '').toLowerCase().includes(query) ? '' : 'none';
          });
        });
      });

      const backToTop = document.getElementById('back-to-top') as HTMLButtonElement | null;
      if (backToTop) {
        const toggleBackToTop = () => {
          const show = window.scrollY > 420;
          backToTop.classList.toggle('is-visible', show);
        };

        backToTop.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        window.addEventListener('scroll', toggleBackToTop, { passive: true });
        toggleBackToTop();
      }
    </script>
  </body>
</html>
