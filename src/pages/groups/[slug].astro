---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const autoPartials = import.meta.glob('/src/content/groups/_auto/*.html', { query: '?raw', import: 'default', eager: true });

export async function getStaticPaths() {
  const groups = await getCollection('groups');
  return groups.map(group => ({
    params: { slug: group.slug },
    props: { group },
  }));
}

const { group } = Astro.props;
const { Content } = await group.render();

const membersHtml = (autoPartials[`/src/content/groups/_auto/${group.slug}.members.html`] as string) ?? '';
const publicationsHtml = (autoPartials[`/src/content/groups/_auto/${group.slug}.publications.html`] as string) ?? '';
const dissertationsHtml = (autoPartials[`/src/content/groups/_auto/${group.slug}.dissertations.html`] as string) ?? '';
---

<Base title={group.data.title}>
  <div class="page-wrapper">
    <nav aria-label="Breadcrumb" style="margin-bottom: 0.75rem;">
      <a href="/groups/" style="text-decoration: underline;">Groups</a>
      <span aria-hidden="true" style="margin: 0 0.5rem;">/</span>
      <span>{group.data.title}</span>
    </nav>
    <h1 style="font-size: 2rem; margin-bottom: 1.25rem;">{group.data.title}</h1>
    <div class="prose">
      <Content />
      <h2>Members</h2>
      <Fragment set:html={membersHtml} />
      <h2>Publications</h2>
      <Fragment set:html={publicationsHtml} />
      <h2>Dissertations</h2>
      <Fragment set:html={dissertationsHtml} />
    </div>
  </div>
</Base>
