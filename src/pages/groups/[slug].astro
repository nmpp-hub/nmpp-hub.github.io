---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const groups = await getCollection('groups');
  return groups.map(group => ({
    params: { slug: group.slug },
    props: { group },
  }));
}

const { group } = Astro.props;
const { Content } = await group.render();
---

<Base title={group.data.title}>
  <div class="page-wrapper">
    <nav aria-label="Breadcrumb" style="margin-bottom: 0.75rem;">
      <a href="/groups/" style="text-decoration: underline;">Groups</a>
      <span aria-hidden="true" style="margin: 0 0.5rem;">/</span>
      <span>{group.data.title}</span>
    </nav>
    <h1 style="font-size: 2rem; margin-bottom: 1.25rem;">{group.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </div>
</Base>
