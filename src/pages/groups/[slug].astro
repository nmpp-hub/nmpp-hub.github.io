---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageLayout from '../../components/PageLayout.astro';

const autoPartials = import.meta.glob('/src/content/groups/_auto/*.html', { query: '?raw', import: 'default', eager: true });

export async function getStaticPaths() {
  const groups = await getCollection('groups');
  return groups.map(group => ({
    params: { slug: group.id },
    props: { group },
  }));
}

const { group } = Astro.props;
const { Content } = await render(group);

const membersHtml = (autoPartials[`/src/content/groups/_auto/${group.id}.members.html`] as string) ?? '';
const publicationsHtml = (autoPartials[`/src/content/groups/_auto/${group.id}.publications.html`] as string) ?? '';
const dissertationsHtml = (autoPartials[`/src/content/groups/_auto/${group.id}.dissertations.html`] as string) ?? '';

const allGroups = (await getCollection('groups')).sort((a, b) => a.data.title.localeCompare(b.data.title));

const leftNav = [{
  heading: 'Groups',
  items: allGroups.map(g => ({
    href: `/groups/${g.id}/`,
    label: g.data.title,
    active: g.id === group.id,
  })),
}];

const tocSections = [
  { id: 'members', label: 'Members' },
  { id: 'publications', label: 'Publications' },
  { id: 'dissertations', label: 'Dissertations' },
];
---

<Base
  title={group.data.title}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Groups', href: '/groups/' },
    { label: group.data.title },
  ]}
>
  <div class="page-wrapper">
    <PageLayout leftNav={leftNav} tocSections={tocSections}>
      <h1 class="page-title">{group.data.title}</h1>
      <div class="prose">
        <Content />
        <h2 id="members">Members</h2>
        <Fragment set:html={membersHtml} />
        <h2 id="publications">Publications</h2>
        <Fragment set:html={publicationsHtml} />
        <h2 id="dissertations">Dissertations</h2>
        <Fragment set:html={dissertationsHtml} />
      </div>
    </PageLayout>
  </div>
</Base>
