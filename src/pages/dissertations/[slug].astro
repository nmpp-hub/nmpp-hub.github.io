---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageLayout from '../../components/PageLayout.astro';
import dissertationsCache from '../../../data/dissertations_cache.json';

type Dissertation = {
  year: number;
  date?: string;
  title: string;
  author: string;
  author_html?: string;
  degree: string;
  institution?: string;
  link: string;
  fulltext?: string;
  codes?: string[];
  groups?: string[];
  bibtex?: string;
};

const DEGREE_LABELS: Record<string, string> = { phd: 'PhD', msc: 'MSc' };

export async function getStaticPaths() {
  const cache = dissertationsCache as Array<Dissertation & { slug: string }>;
  return cache.map(d => ({
    params: { slug: d.slug },
    props: { dissertation: d },
  }));
}

const { dissertation } = Astro.props as { dissertation: Dissertation & { slug: string } };
const slug = dissertation.slug;

const allAbstracts = await getCollection('dissertations');
const abstractEntry = allAbstracts.find(e => e.id === slug);
const { Content } = abstractEntry ? await render(abstractEntry) : { Content: undefined };

const degree = DEGREE_LABELS[dissertation.degree] ?? dissertation.degree;
const codes = await getCollection('codes');
const codeTitleBySlug = new Map(codes.map(c => [c.id, c.data.title]));
const relatedCodes = (dissertation.codes ?? []).filter(Boolean);
const libraryLink = dissertation.link?.trim() ?? '';
const fulltextLink = dissertation.fulltext?.trim() ?? '';
const displayDate = dissertation.date?.trim() || String(dissertation.year);
const bibtex = dissertation.bibtex?.trim() ?? '';

function formatBibtexEntry(entry: string): string {
  return entry.replace(/(@\w+{[^}]+},?\s*)/g, '$1\n');
}

const bibtexDisplay = bibtex ? formatBibtexEntry(bibtex) : '';

function firstAuthorLastName(author: string | undefined): string {
  if (!author || author.trim() === '') {
    return 'Unknown';
  }
  const words = author.trim().split(/\s+/);
  return words[words.length - 1];
}

const path = Astro.url.pathname;

const allDissertations = dissertationsCache as Array<{ slug: string; author: string; year: number }>;
const dissertationNavItems = [...allDissertations]
  .sort((a, b) => b.year - a.year)
  .map(d => ({
    href: `/dissertations/${d.slug}/`,
    label: `${firstAuthorLastName(d.author)}, ${d.year}`,
    active: d.slug === slug,
  }));

const leftNav = [
  {
    heading: 'Navigate',
    items: [
      { href: '/', label: 'Home', active: path === '/' },
      { href: '/codes/', label: 'Codes', active: path.startsWith('/codes') },
      { href: '/groups/', label: 'Groups', active: path.startsWith('/groups') },
      { href: '/members/', label: 'Members', active: path.startsWith('/members') },
      { href: '/publications/', label: 'Publications', active: path.startsWith('/publications') },
      { href: '/dissertations/', label: 'Dissertations', active: path.startsWith('/dissertations') },
      { href: '/about/', label: 'About', active: path.startsWith('/about') },
    ],
  },
  {
    heading: 'All Dissertations',
    items: dissertationNavItems,
  },
];

const tocSections = [
  { id: 'abstract', label: 'Abstract' },
  { id: 'bibtex', label: 'BibTeX' },
];
---

<Base
  title={dissertation.title}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Dissertations', href: '/dissertations/' },
    { label: dissertation.title },
  ]}
>
  <div class="page-wrapper">
    <PageLayout leftNav={leftNav} tocSections={tocSections}>
      <h1 class="page-title">{dissertation.title}</h1>
      <div class="prose">
        <p><strong set:html={dissertation.author_html || dissertation.author}></strong></p>
        <p class="publication-meta-summary">
          {displayDate} · {degree}{dissertation.institution ? ` · ${dissertation.institution}` : ''}
          {(dissertation as any).group_slug && <span> · <a href={`/groups/${(dissertation as any).group_slug}/`}>{(dissertation as any).group}</a></span>}
          {relatedCodes.map(code => <span> · <a href={`/codes/${code}/`}>{codeTitleBySlug.get(code) ?? code}</a></span>)}
        </p>
        {(libraryLink || fulltextLink) && (
          <div class="publication-actions">
            {libraryLink && (
              <a href={libraryLink} class="publication-action-link publication-action-secondary" target="_blank" rel="noopener noreferrer">Library page</a>
            )}
            {fulltextLink && (
              <a href={fulltextLink} class="publication-action-link" target="_blank" rel="noopener noreferrer">Full text</a>
            )}
          </div>
        )}

        <h2 id="abstract">Abstract</h2>
        {Content ? (
          <Content />
        ) : (
          <p class="publication-empty">No abstract available.</p>
        )}

        <div class="publication-section-heading" id="bibtex">
          <h2>BibTeX</h2>
          {bibtexDisplay && (
            <button class="publication-copy-button" type="button" data-copy-target="publication-bibtex-code">
              Copy
            </button>
          )}
        </div>
        {bibtex ? (
          <pre class="publication-bibtex"><code id="publication-bibtex-code">{bibtexDisplay}</code></pre>
        ) : (
          <p class="publication-empty">No BibTeX entry was returned for this dissertation.</p>
        )}
      </div>
    </PageLayout>
  </div>
</Base>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const button = document.querySelector('.publication-copy-button');
    if (!(button instanceof HTMLButtonElement)) return;

    button.addEventListener('click', async () => {
      const targetId = button.dataset.copyTarget;
      if (!targetId) return;
      const target = document.getElementById(targetId);
      if (!target) return;

      try {
        await navigator.clipboard.writeText(target.textContent ?? '');
        const originalText = button.textContent;
        button.textContent = 'Copied';
        window.setTimeout(() => {
          button.textContent = originalText;
        }, 1600);
      } catch {
        button.textContent = 'Failed';
        window.setTimeout(() => {
          button.textContent = 'Copy';
        }, 1600);
      }
    });
  });
</script>
