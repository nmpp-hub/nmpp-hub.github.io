---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CodeGallery from '../../components/CodeGallery';

const autoPartials = import.meta.glob('/src/content/codes/_auto/*.html', { query: '?raw', import: 'default', eager: true });

export async function getStaticPaths() {
  const codes = await getCollection('codes');
  return codes.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const normalizedPath = entry.data.path?.endsWith('/')
  ? entry.data.path
  : `${entry.data.path}/`;

const membersHtml = (autoPartials[`/src/content/codes/_auto/${entry.id}.members.html`] as string) ?? '';
const publicationsHtml = (autoPartials[`/src/content/codes/_auto/${entry.id}.publications.html`] as string) ?? '';
const dissertationsHtml = (autoPartials[`/src/content/codes/_auto/${entry.id}.dissertations.html`] as string) ?? '';
---

<Base
  title={entry.data.title}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Codes', href: '/codes/' },
    { label: entry.data.title },
  ]}
>
  <div class="page-wrapper">
    <h1 style="font-size: 2rem; margin-bottom: 1.25rem;">{entry.data.title}</h1>
    <div class="prose">
      {entry.data.gallery && entry.data.gallery.length > 0 && (
        <>
          {/* <h2>Gallery</h2> */}
          <CodeGallery client:load images={entry.data.gallery} />
        </>
      )}
      <Content />
      <h2>Members</h2>
      <Fragment set:html={membersHtml} />
      <h2>Publications</h2>
      <Fragment set:html={publicationsHtml} />
      <h2>Dissertations</h2>
      <Fragment set:html={dissertationsHtml} />
    </div>
  </div>
</Base>
