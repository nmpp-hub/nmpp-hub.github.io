---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

const autoPartials = import.meta.glob('/src/content/members/_auto/*.html', { query: '?raw', import: 'default', eager: true });

export async function getStaticPaths() {
  const members = await getCollection('members');
  return members.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const profileHtml = (autoPartials[`/src/content/members/_auto/${entry.id}.profile.html`] as string) ?? '';
const publicationsHtml = (autoPartials[`/src/content/members/_auto/${entry.id}.publications.html`] as string) ?? '';
const dissertationsHtml = (autoPartials[`/src/content/members/_auto/${entry.id}.dissertations.html`] as string) ?? '';
---

<Base
  title={entry.data.title}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Members', href: '/members/' },
    { label: entry.data.title },
  ]}
>
  <div class="page-wrapper">
    <h1 style="font-size: 2rem; margin-bottom: 1.25rem;">{entry.data.title}</h1>
    <div class="prose">
      <h2>Profile</h2>
      <Fragment set:html={profileHtml} />
      <Content />
      <h2>Publications</h2>
      <Fragment set:html={publicationsHtml} />
      <h2>Dissertations</h2>
      <Fragment set:html={dissertationsHtml} />
    </div>
  </div>
</Base>
