---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageLayout from '../../components/PageLayout.astro';

const autoPartials = import.meta.glob('/src/content/members/_auto/*.html', { query: '?raw', import: 'default', eager: true });

export async function getStaticPaths() {
  const members = await getCollection('members');
  return members.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const profileHtml = (autoPartials[`/src/content/members/_auto/${entry.id}.profile.html`] as string) ?? '';
const publicationsHtml = (autoPartials[`/src/content/members/_auto/${entry.id}.publications.html`] as string) ?? '';
const dissertationsHtml = (autoPartials[`/src/content/members/_auto/${entry.id}.dissertations.html`] as string) ?? '';

const allMembers = (await getCollection('members')).sort((a, b) => a.data.title.localeCompare(b.data.title));

const leftNav = [{
  heading: 'Members',
  items: allMembers.map(m => ({
    href: `/members/${m.id}/`,
    label: m.data.title,
    active: m.id === entry.id,
  })),
}];

const tocSections = [
  { id: 'profile', label: 'Profile' },
  { id: 'publications', label: 'Publications' },
  { id: 'dissertations', label: 'Dissertations' },
];
---

<Base
  title={entry.data.title}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Members', href: '/members/' },
    { label: entry.data.title },
  ]}
>
  <div class="page-wrapper">
    <PageLayout leftNav={leftNav} tocSections={tocSections}>
      <h1 class="page-title">{entry.data.title}</h1>
      <div class="prose">
        <h2 id="profile">Profile</h2>
        <Fragment set:html={profileHtml} />
        <Content />
        <h2 id="publications">Publications</h2>
        <Fragment set:html={publicationsHtml} />
        <h2 id="dissertations">Dissertations</h2>
        <Fragment set:html={dissertationsHtml} />
      </div>
    </PageLayout>
  </div>
</Base>
