---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const members = await getCollection('members');
  return members.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Base title={entry.data.title}>
  <div class="page-wrapper">
    <nav aria-label="Breadcrumb" style="margin-bottom: 0.75rem;">
      <a href="/members/" style="text-decoration: underline;">Members</a>
      <span aria-hidden="true" style="margin: 0 0.5rem;">/</span>
      <span>{entry.data.title}</span>
    </nav>
    <h1 style="font-size: 2rem; margin-bottom: 1.25rem;">{entry.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </div>
</Base>
