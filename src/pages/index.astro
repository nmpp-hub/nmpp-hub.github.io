---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import latestResearchData from '../../data/latest_research.json';

const codes = await getCollection('codes');
const groups = await getCollection('groups');

const topCodes = [...codes].sort((a, b) => a.data.title.localeCompare(b.data.title)).slice(0, 6);
const topGroups = [...groups].sort((a, b) => a.data.title.localeCompare(b.data.title)).slice(0, 6);

// Get latest research items
const latestItems = latestResearchData.items || [];
---

<Base title="NMPP Division">
  <div class="page-wrapper nmpp-home">
    <!-- Hero Section -->
    <section class="home-hero">
      <div class="home-hero-copy">
        <p class="home-eyebrow">Numerical Methods for Plasma Physics</p>
        <h1>NMPP Division at the Max Planck Institute for Plasma Physics</h1>
        <p class="home-intro">
          We develop advanced numerical methods, high-performance simulation software, and data-driven tools
          for plasma physics across magnetic confinement, geometric integration, and uncertainty quantification.
        </p>
        <div class="home-hero-actions">
          <a class="home-btn home-btn-primary" href="/codes/">Explore Codes</a>
          <a class="home-btn home-btn-secondary" href="/groups/">Explore Groups</a>
        </div>
      </div>
      <div class="home-hero-visual" aria-hidden="true">
        <div class="home-hero-slideshow" data-home-slideshow>
          <div class="home-slide is-active">
            <img src="/images/banner1.png" alt="Wendelstein 7-X related numerical plasma simulation visual" />
            <div class="home-slide-caption">
              <strong>Figure Slot 01</strong>
              Add your first highlight image and caption here.
            </div>
          </div>
          <div class="home-slide">
            <img src="/images/banner2.jpg" alt="High-performance plasma computation visualization" />
            <div class="home-slide-caption">
              <strong>Figure Slot 02</strong>
              Showcase another method, simulation, or project snapshot.
            </div>
          </div>
          <div class="home-slide">
            <img src="/images/banner3.png" alt="Numerical method visual with geometric structures" />
            <div class="home-slide-caption">
              <strong>Figure Slot 03</strong>
              Use this panel for updates, milestones, or visual results.
            </div>
          </div>
          <div class="home-slide-dots" data-home-slide-dots>
            <button type="button" class="home-slide-dot is-active" aria-label="Show slide 1"></button>
            <button type="button" class="home-slide-dot" aria-label="Show slide 2"></button>
            <button type="button" class="home-slide-dot" aria-label="Show slide 3"></button>
          </div>
        </div>
      </div>
    </section>

    <!-- Latest Publications/Dissertations Slideshow -->
    <section class="home-latest">
      <h2>Latest Research Output</h2>
      <div class="latest-slideshow" data-latest-slideshow>
        {latestItems.map((item, index) => (
          <div class={`latest-slide ${index === 0 ? 'is-active' : ''}`}>
            <div class="slide-content">
              <div class="slide-type">{item.type === 'publication' ? 'Publication' : 'Dissertation'}</div>
              <h3>{item.title}</h3>
              {item.type === 'publication' ? (
                <>
                  <p class="slide-meta">
                    <span class="slide-year">{item.year}</span>
                    {item.authors && <span class="slide-authors">{item.authors}</span>}
                  </p>
                  {item.abstract && <p class="slide-description">{item.abstract.substring(0, 150)}...</p>}
                  <a href={item.url} class="slide-link">Read Publication →</a>
                </>
              ) : (
                <>
                  <p class="slide-meta">
                    <span class="slide-year">{item.year}</span>
                    <span class="slide-authors">{item.degree} by {item.author}</span>
                  </p>
                  <p class="slide-description">{item.abstract}</p>
                  <a href={item.link} class="slide-link">Read Dissertation →</a>
                </>
              )}
            </div>
          </div>
        ))}
        <div class="slide-dots-container" data-latest-dots>
          {latestItems.map((_, i) => (
            <button class={`slide-dot-small ${i === 0 ? 'is-active' : ''}`} data-dot={i} aria-label={`Go to slide ${i + 1}`}></button>
          ))}
        </div>
        <div class="latest-controls">
          <button class="latest-prev" data-prev-btn aria-label="Previous slide">‹</button>
          <button class="latest-next" data-next-btn aria-label="Next slide">›</button>
        </div>
      </div>
    </section>

    <!-- Compact Navigation -->
    <section class="home-compact-nav">
      <div class="nav-section">
        <h3>Research Groups</h3>
        <div class="compact-links">
          {topGroups.map((group) => (
            <a href={`/groups/${group.slug}/`} class="compact-link">{group.data.title}</a>
          ))}
        </div>
      </div>

      <div class="nav-section">
        <h3>Software Codes</h3>
        <div class="compact-links">
          {topCodes.map((code) => (
            <a href={`/codes/${code.slug}/`} class="compact-link">{code.data.title}</a>
          ))}
        </div>
      </div>

      <div class="nav-section">
        <h3>Quick Links</h3>
        <div class="compact-links">
          <a href="/about/" class="compact-link">About</a>
          <a href="/members/" class="compact-link">Team Members</a>
          <a href="/publications/" class="compact-link">Publications</a>
          <a href="/dissertations/" class="compact-link">Dissertations</a>
          <a href="https://github.com/nmpp-hub" target="_blank" rel="noopener noreferrer" class="compact-link">GitHub</a>
        </div>
      </div>
    </section>
  </div>
</Base>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Hero slideshow
    const slideshow = document.querySelector('[data-home-slideshow]');
    if (slideshow) {
      const slides = Array.from(slideshow.querySelectorAll('.home-slide'));
      const dots = Array.from(slideshow.querySelectorAll('.home-slide-dot'));
      if (slides.length > 0 && dots.length > 0) {
        let current = 0;
        let timer: ReturnType<typeof setInterval> | null = null;

        const setSlide = (index: number) => {
          slides.forEach((slide, i) => slide.classList.toggle('is-active', i === index));
          dots.forEach((dot, i) => dot.classList.toggle('is-active', i === index));
          current = index;
        };

        const start = () => {
          if (timer) clearInterval(timer);
          timer = setInterval(() => {
            setSlide((current + 1) % slides.length);
          }, 4800);
        };

        dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            setSlide(index);
            start();
          });
        });

        setSlide(0);
        start();
      }
    }

    // Latest research slideshow
    const latestSlideshow = document.querySelector('[data-latest-slideshow]');
    if (latestSlideshow) {
      const slides = Array.from(latestSlideshow.querySelectorAll('.latest-slide'));
      const dotsContainer = latestSlideshow.querySelector('[data-latest-dots]');
      const dots = dotsContainer ? Array.from(dotsContainer.querySelectorAll('.slide-dot-small')) : [];
      const prevBtn = latestSlideshow.querySelector('[data-prev-btn]');
      const nextBtn = latestSlideshow.querySelector('[data-next-btn]');

      if (slides.length > 0) {
        let current = 0;
        let timer: ReturnType<typeof setInterval> | null = null;

        const setSlide = (index: number) => {
          slides.forEach((slide, i) => slide.classList.toggle('is-active', i === index));
          dots.forEach((dot, i) => {
            dot.classList.toggle('is-active', i === index);
          });
          current = index;
        };

        const start = () => {
          if (timer) clearInterval(timer);
          timer = setInterval(() => {
            setSlide((current + 1) % slides.length);
          }, 6000);
        };

        dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            setSlide(index);
            start();
          });
        });

        if (prevBtn) {
          prevBtn.addEventListener('click', () => {
            setSlide((current - 1 + slides.length) % slides.length);
            start();
          });
        }

        if (nextBtn) {
          nextBtn.addEventListener('click', () => {
            setSlide((current + 1) % slides.length);
            start();
          });
        }

        setSlide(0);
        start();
      }
    }
  });
</script>
