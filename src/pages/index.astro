---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const codes = await getCollection('codes');
const groups = await getCollection('groups');

const topCodes = [...codes].sort((a, b) => a.data.title.localeCompare(b.data.title)).slice(0, 6);
const topGroups = [...groups].sort((a, b) => a.data.title.localeCompare(b.data.title)).slice(0, 6);
---

<Base title="NMPP Division">
  <div class="page-wrapper nmpp-home">
    <section class="home-hero">
      <div class="home-hero-copy">
        <p class="home-eyebrow">Numerical Methods for Plasma Physics</p>
        <h1>NMPP Division at the Max Planck Institute for Plasma Physics</h1>
        <p class="home-intro">
          We develop advanced numerical methods, high-performance simulation software, and data-driven tools
          for plasma physics across magnetic confinement, geometric integration, and uncertainty quantification.
        </p>
        <div class="home-hero-actions">
          <a class="home-btn home-btn-primary" href="/codes/">Explore Codes</a>
          <a class="home-btn home-btn-secondary" href="/groups/">Explore Groups</a>
        </div>
      </div>
      <div class="home-hero-visual" aria-hidden="true">
        <div class="home-hero-slideshow" data-home-slideshow>
          <div class="home-slide is-active">
            <img src="/images/banner1.png" alt="Wendelstein 7-X related numerical plasma simulation visual" />
            <div class="home-slide-caption">
              <strong>Figure Slot 01</strong>
              Add your first highlight image and caption here.
            </div>
          </div>
          <div class="home-slide">
            <img src="/images/banner2.jpg" alt="High-performance plasma computation visualization" />
            <div class="home-slide-caption">
              <strong>Figure Slot 02</strong>
              Showcase another method, simulation, or project snapshot.
            </div>
          </div>
          <div class="home-slide">
            <img src="/images/banner3.png" alt="Numerical method visual with geometric structures" />
            <div class="home-slide-caption">
              <strong>Figure Slot 03</strong>
              Use this panel for updates, milestones, or visual results.
            </div>
          </div>
          <div class="home-slide-dots" data-home-slide-dots>
            <button type="button" class="home-slide-dot is-active" aria-label="Show slide 1"></button>
            <button type="button" class="home-slide-dot" aria-label="Show slide 2"></button>
            <button type="button" class="home-slide-dot" aria-label="Show slide 3"></button>
          </div>
        </div>
        <!-- <div class="home-banner-card home-banner-card-side">
          <span>Geometry</span>
          <span>HPC</span>
          <span>Data Analysis</span>
        </div> -->
      </div>
    </section>

    <!-- <section class="home-explore-grid" aria-label="Primary site sections">
      <a class="home-explore-card" href="/codes/">
        <p>Software</p>
        <h2>Codes</h2>
        <span>Browse all NMPP simulation and analysis codes</span>
      </a>
      <a class="home-explore-card" href="/groups/">
        <p>Research</p>
        <h2>Groups</h2>
        <span>Discover the thematic research teams in NMPP</span>
      </a>
      <a class="home-explore-card" href="/members/">
        <p>People</p>
        <h2>Members</h2>
        <span>Find scientists, students, and collaborators</span>
      </a>
      <a class="home-explore-card" href="/publications/">
        <p>Results</p>
        <h2>Publications</h2>
        <span>Search papers and dissertation outputs</span>
      </a>
    </section> -->

    <section class="home-discovery">
      <article class="home-discovery-block">
        <div class="home-section-head">
          <h2>Codes</h2>
          <a href="/codes/">View all codes</a>
        </div>
        <div class="home-link-grid">
          {topCodes.map((code) => (
            <a href={`/codes/${code.slug}/`} class="home-link-card">
              <strong>{code.data.title}</strong>
              <span>Open code page</span>
            </a>
          ))}
        </div>
      </article>

      <article class="home-discovery-block">
        <div class="home-section-head">
          <h2>Research Groups</h2>
          <a href="/groups/">View all groups</a>
        </div>
        <div class="home-link-grid">
          {topGroups.map((group) => (
            <a href={`/groups/${group.slug}/`} class="home-link-card">
              <strong>{group.data.title}</strong>
              <span>Open group page</span>
            </a>
          ))}
        </div>
      </article>
    </section>

    <section class="home-results">
      <a class="home-results-card" href="/publications/">
        <h3>Publications</h3>
        <p>See all publications by members of NMPP.</p>
      </a>
      <a class="home-results-card" href="/dissertations/">
        <h3>Dissertations</h3>
        <p>See all dissertations from members of NMPP.</p>
      </a>
      <a class="home-results-card" href="/members/">
        <h3>Members</h3>
        <p>See all members of the NMPP division.</p>
      </a>
      <a class="home-results-card" href="https://www.ipp.mpg.de/ippcms/eng/for/bereiche/numerik">
        <h3>Official IPP Page</h3>
        <p>Visit the institutional webpage for the NMPP division at IPP.</p>
      </a>
      <a class="home-results-card" href="https://github.com/nmpp-hub" target="_blank" rel="noopener noreferrer">
        <h3>GitHub Organization</h3>
        <p>Browse repositories, code activity, and open-source tools from NMPP.</p>
      </a>
    </section>
  </div>
</Base>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slideshow = document.querySelector('[data-home-slideshow]');
    if (!slideshow) return;

    const slides = Array.from(slideshow.querySelectorAll('.home-slide'));
    const dots = Array.from(slideshow.querySelectorAll('.home-slide-dot'));
    if (slides.length === 0 || dots.length === 0) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    const setSlide = (index: number) => {
      slides.forEach((slide, i) => slide.classList.toggle('is-active', i === index));
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === index));
      current = index;
    };

    const start = () => {
      if (timer) clearInterval(timer);
      timer = setInterval(() => {
        setSlide((current + 1) % slides.length);
      }, 4800);
    };

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        setSlide(index);
        start();
      });
    });

    setSlide(0);
    start();
  });
</script>
