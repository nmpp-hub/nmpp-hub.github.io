---
import Base from '../layouts/Base.astro';
import PageLayout from '../components/PageLayout.astro';

const path = Astro.url.pathname;
const leftNav = [{
  heading: 'Navigate',
  items: [
    { href: '/', label: 'Home', active: path === '/' },
    { href: '/codes/', label: 'Codes', active: path.startsWith('/codes') },
    { href: '/groups/', label: 'Groups', active: path.startsWith('/groups') },
    { href: '/members/', label: 'Members', active: path.startsWith('/members') },
    { href: '/publications/', label: 'Publications', active: path.startsWith('/publications') },
    { href: '/dissertations/', label: 'Dissertations', active: path.startsWith('/dissertations') },
    { href: '/about/', label: 'About', active: path.startsWith('/about') },
  ],
}];

const tocSections = [
  { id: 'overview', label: 'Overview' },
  { id: 'research', label: 'Research' },
  { id: 'resources', label: 'Resources' },
];
---

<Base title="NMPP Division">
  <div class="page-wrapper">
    <PageLayout leftNav={leftNav} tocSections={tocSections}>
      <div class="page-header">
        <h1>Numerical Methods for Plasma Physics</h1>
        <p>NMPP Division at the Max Planck Institute for Plasma Physics</p>
      </div>
      <div class="prose">
        <h2 id="overview">Overview</h2>
        <p>
          The Numerical Methods for Plasma Physics (NMPP) division develops advanced numerical methods,
          high-performance simulation software, and data-driven tools for plasma physics. Our work spans
          geometric integration, structure-preserving finite element methods, kinetic simulation,
          magnetohydrodynamics, and probabilistic data analysis.
        </p>
        <p>
          We work with applications to magnetic confinement fusion in tokamaks and stellarators such as
          <a href="https://www.ipp.mpg.de/w7x" target="_blank" rel="noopener noreferrer">Wendelstein 7-X</a>.
        </p>

        <h2 id="research">Research</h2>
        <p>
          Our <a href="/groups/">research groups</a> develop specialized codes and methods:
        </p>
        <ul>
          <li><a href="/groups/geometric-numerical-integration/">Geometric Numerical Integration</a> — symplectic and variational integrators</li>
          <li><a href="/groups/finite-element-methods/">Finite Element Methods</a> — compatible discretizations based on de Rham sequences</li>
          <li><a href="/groups/kinetic-gyrokinetic-models/">Kinetic and Gyrokinetic Models</a> — Vlasov and gyrokinetic simulation</li>
          <li><a href="/groups/magnetohydrodynamics/">Magnetohydrodynamics</a> — 3D MHD equilibria and hybrid codes</li>
          <li><a href="/groups/zonal-flows-turbulent/">Zonal Flows in Turbulent Plasmas</a> — turbulence and fusion devices</li>
          <li><a href="/groups/probabilistic-data-analysis/">Probabilistic Data Analysis</a> — Bayesian methods and machine learning</li>
          <li><a href="/groups/advanced-computing-hub/">Advanced Computing Hub</a> — HPC infrastructure and deployment</li>
        </ul>

        <h2 id="resources">Resources</h2>
        <p>
          Explore our <a href="/codes/">software codes</a>, <a href="/publications/">publications</a>,
          and <a href="/dissertations/">dissertations</a>. Learn more <a href="/about/">about the division</a>
          or contact the <a href="/members/">team members</a>.
        </p>
        <p>
          <a href="https://github.com/nmpp-hub" target="_blank" rel="noopener noreferrer">GitHub</a>
          &middot;
          <a href="https://www.ipp.mpg.de/ippcms/eng/for/bereiche/numerik" target="_blank" rel="noopener noreferrer">IPP division webpage</a>
        </p>
      </div>
    </PageLayout>
  </div>
</Base>
